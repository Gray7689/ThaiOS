#!/bin/bash
#
# ThaiOS Configure Script
#

set -e

THAIOS_ROOT="$(cd "$(dirname "$0")" && pwd)"
PREFIX="/usr"
ENABLE_KERNEL="yes"
ENABLE_COMPOSITOR="yes"
ENABLE_DESKTOP="yes"
ENABLE_APPS="yes"
ENABLE_PKG="yes"
ENABLE_INSTALLER="yes"
ENABLE_UPDATER="yes"
BUILD_TYPE="release"
JOBS=$(nproc 2>/dev/null || echo 4)

log() { echo -e "\033[1;32m[ThaiOS]\033[0m $*"; }

show_help() {
    cat << 'HELP'
ThaiOS Configure Script
=======================

Opzioni:
  --prefix=PREFIX       Directory di installazione (default: /usr)
  --enable-kernel       Compila kernel (default: yes)
  --disable-kernel      Salta compilazione kernel
  --enable-compositor   Compila compositor (default: yes)
  --disable-compositor  Salta compilazione compositor
  --enable-desktop      Compila componenti desktop (default: yes)
  --disable-desktop     Salta compilazione desktop
  --enable-apps         Compila applicazioni (default: yes)
  --disable-apps        Salta compilazione applicazioni
  --enable-pkg          Compila package manager (default: yes)
  --disable-pkg         Salta package manager
  --enable-installer    Compila installer (default: yes)
  --disable-installer   Salta installer
  --enable-updater      Compila updater (default: yes)
  --disable-updater     Salta updater
  --build-type=TYPE     Tipo di build (release|debug, default: release)
  --jobs=N              Numero di job paralleli (default: auto)
  --help                Mostra questo aiuto
HELP
}

while [ $# -gt 0 ]; do
    case "$1" in
        --prefix=*) PREFIX="${1#*=}" ;;
        --enable-kernel) ENABLE_KERNEL="yes" ;;
        --disable-kernel) ENABLE_KERNEL="no" ;;
        --enable-compositor) ENABLE_COMPOSITOR="yes" ;;
        --disable-compositor) ENABLE_COMPOSITOR="no" ;;
        --enable-desktop) ENABLE_DESKTOP="yes" ;;
        --disable-desktop) ENABLE_DESKTOP="no" ;;
        --enable-apps) ENABLE_APPS="yes" ;;
        --disable-apps) ENABLE_APPS="no" ;;
        --enable-pkg) ENABLE_PKG="yes" ;;
        --disable-pkg) ENABLE_PKG="no" ;;
        --enable-installer) ENABLE_INSTALLER="yes" ;;
        --disable-installer) ENABLE_INSTALLER="no" ;;
        --enable-updater) ENABLE_UPDATER="yes" ;;
        --disable-updater) ENABLE_UPDATER="no" ;;
        --build-type=*) BUILD_TYPE="${1#*=}" ;;
        --jobs=*) JOBS="${1#*=}" ;;
        --help|-h) show_help; exit 0 ;;
        *) echo "Opzione sconosciuta: $1"; show_help; exit 1 ;;
    esac
    shift
done

# Check dependencies
DEPS_MISSING=""

check_dep() {
    if ! command -v "$1" &> /dev/null; then
        DEPS_MISSING="$DEPS_MISSING $1"
    fi
}

# Build dependencies
check_dep "gcc" || check_dep "clang"
check_dep "make"
check_dep "pkg-config"
check_dep "python3"

if [ -n "$DEPS_MISSING" ]; then
    echo "ATTENZIONE: Dipendenze mancanti:$DEPS_MISSING"
    echo "ThaiOS potrebbe non compilare correttamente."
fi

# Write config
cat > "$THAIOS_ROOT/build.config" << EOF
# ThaiOS Build Configuration
# Generated by configure

THAIOS_ROOT="$THAIOS_ROOT"
PREFIX="$PREFIX"
ENABLE_KERNEL="$ENABLE_KERNEL"
ENABLE_COMPOSITOR="$ENABLE_COMPOSITOR"
ENABLE_DESKTOP="$ENABLE_DESKTOP"
ENABLE_APPS="$ENABLE_APPS"
ENABLE_PKG="$ENABLE_PKG"
ENABLE_INSTALLER="$ENABLE_INSTALLER"
ENABLE_UPDATER="$ENABLE_UPDATER"
BUILD_TYPE="$BUILD_TYPE"
JOBS="$JOBS"
EOF

log "ThaiOS configurato:"
log "  Prefix: $PREFIX"
log "  Build type: $BUILD_TYPE"
log "  Jobs: $JOBS"
log "  Compositor: $ENABLE_COMPOSITOR"
log "  Desktop: $ENABLE_DESKTOP"
log "  Apps: $ENABLE_APPS"
log "  Kernel: $ENABLE_KERNEL"
log ""
log "Esegui 'make' per compilare ThaiOS."
