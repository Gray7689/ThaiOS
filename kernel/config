#
# ThaiOS Kernel Configuration
# Based on Linux 6.6.x LTS
#

CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=64
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_HZ_1000=y

# ThaiOS branding
CONFIG_DEFAULT_HOSTNAME="ThaiOS"

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_XFS_FS=y
CONFIG_NTFS3_FS=y
CONFIG_NTFS3_FS_POSIX_ACL=y
CONFIG_FUSE_FS=y

# ThaiOS specific drivers
CONFIG_THAIOS_BOOT_SPLASH=y

# Graphics
CONFIG_DRM=y
CONFIG_DRM_I915=y
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_NOUVEAU=y
CONFIG_DRM_VIRTIO_GPU=y

# USB
CONFIG_USB=y
CONFIG_USB_HID=y
CONFIG_USB_STORAGE=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y

# Network
CONFIG_NET=y
CONFIG_WIRELESS=y
CONFIG_WEXT=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y

# Sound
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_USB_AUDIO=y

# Virtualization
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=y
CONFIG_KVM_INTEL=y
CONFIG_KVM_AMD=y
CONFIG_VHOST_NET=y

# Security
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_YAMA=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y

# ThaiOS optimizations
CONFIG_THAIOS_OPTIMIZED_SCHEDULER=y
CONFIG_THAIOS_MEMORY_MANAGER=y
CONFIG_THAIOS_IO_SCHEDULER="mq-deadline"
